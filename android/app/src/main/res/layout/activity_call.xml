<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF000000">

    <!-- Voice call background gradient -->
    <View
        android:id="@+id/voice_bg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_call_activity"
        android:visibility="gone" />

    <!-- Remote video (full screen) -->
    <org.webrtc.SurfaceViewRenderer
        android:id="@+id/remote_video"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Placeholder when remote camera is off -->
    <LinearLayout
        android:id="@+id/remote_no_video"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:background="#FF1A1A2E"
        android:visibility="gone">

        <TextView
            android:id="@+id/remote_avatar_text"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:background="@drawable/btn_accept_call"
            android:gravity="center"
            android:textSize="40sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/remote_no_video_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Camera off"
            android:textColor="#99FFFFFF"
            android:textSize="14sp"
            android:layout_marginTop="12dp" />
    </LinearLayout>

    <!-- Local video preview (draggable corner) -->
    <org.webrtc.SurfaceViewRenderer
        android:id="@+id/local_video"
        android:layout_width="120dp"
        android:layout_height="160dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="16dp"
        android:elevation="4dp" />

    <!-- Voice call center: avatar + pulse rings -->
    <LinearLayout
        android:id="@+id/voice_center"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">

        <FrameLayout
            android:layout_width="140dp"
            android:layout_height="140dp">

            <View
                android:id="@+id/pulse_ring_outer"
                android:layout_width="140dp"
                android:layout_height="140dp"
                android:layout_gravity="center"
                android:background="@drawable/btn_accept_call"
                android:alpha="0.15" />

            <View
                android:id="@+id/pulse_ring_inner"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_gravity="center"
                android:background="@drawable/btn_accept_call"
                android:alpha="0.25" />

            <TextView
                android:id="@+id/avatar_text"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_gravity="center"
                android:background="@drawable/btn_accept_call"
                android:gravity="center"
                android:textSize="40sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />
        </FrameLayout>
    </LinearLayout>

    <!-- Top status bar -->
    <LinearLayout
        android:id="@+id/top_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingTop="0dp"
        android:paddingBottom="16dp"
        android:background="#80000000">

        <TextView
            android:id="@+id/caller_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/call_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#CCCCCC"
            android:textSize="14sp"
            android:layout_marginTop="4dp" />
    </LinearLayout>

    <!-- Bottom controls -->
    <LinearLayout
        android:id="@+id/controls_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingBottom="0dp"
        android:paddingTop="24dp"
        android:background="#80000000">

        <!-- Row 1: Mute, Video, Flip, Audio Route -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <ImageButton
                    android:id="@+id/btn_mute"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:background="@drawable/btn_call_control"
                    android:src="@drawable/ic_mic"
                    android:scaleType="centerInside"
                    android:contentDescription="Mute"
                    android:padding="14dp" />

                <TextView
                    android:id="@+id/label_mute"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mute"
                    android:textColor="#BBFFFFFF"
                    android:textSize="11sp"
                    android:layout_marginTop="6dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <ImageButton
                    android:id="@+id/btn_video"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:background="@drawable/btn_call_control"
                    android:src="@drawable/ic_videocam"
                    android:scaleType="centerInside"
                    android:contentDescription="Video"
                    android:padding="14dp" />

                <TextView
                    android:id="@+id/label_video"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Video"
                    android:textColor="#BBFFFFFF"
                    android:textSize="11sp"
                    android:layout_marginTop="6dp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/flip_container"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <ImageButton
                    android:id="@+id/btn_flip"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:background="@drawable/btn_call_control"
                    android:src="@drawable/ic_flip_camera"
                    android:scaleType="centerInside"
                    android:contentDescription="Flip Camera"
                    android:padding="14dp" />

                <TextView
                    android:id="@+id/label_flip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Flip"
                    android:textColor="#BBFFFFFF"
                    android:textSize="11sp"
                    android:layout_marginTop="6dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <ImageButton
                    android:id="@+id/btn_audio_route"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:background="@drawable/btn_call_control"
                    android:src="@drawable/ic_volume_up"
                    android:scaleType="centerInside"
                    android:contentDescription="Audio Route"
                    android:padding="14dp" />

                <TextView
                    android:id="@+id/label_audio_route"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Speaker"
                    android:textColor="#BBFFFFFF"
                    android:textSize="11sp"
                    android:layout_marginTop="6dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Hang up button -->
        <ImageButton
            android:id="@+id/btn_hangup"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:background="@drawable/btn_call_hangup"
            android:src="@drawable/ic_call_end"
            android:scaleType="centerInside"
            android:contentDescription="Hang Up"
            android:padding="18dp" />
    </LinearLayout>

</FrameLayout>
