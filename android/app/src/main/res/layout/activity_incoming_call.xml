<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_incoming_call">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <!-- Top spacer -->
        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="3" />

        <!-- Pulse ring + avatar -->
        <FrameLayout
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:layout_gravity="center">

            <View
                android:id="@+id/pulse_ring_outer"
                android:layout_width="140dp"
                android:layout_height="140dp"
                android:layout_gravity="center"
                android:background="@drawable/btn_accept_call"
                android:alpha="0.15" />

            <View
                android:id="@+id/pulse_ring_inner"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_gravity="center"
                android:background="@drawable/btn_accept_call"
                android:alpha="0.25" />

            <TextView
                android:id="@+id/avatar_text"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_gravity="center"
                android:background="@drawable/btn_accept_call"
                android:gravity="center"
                android:textColor="#FFFFFF"
                android:textSize="40sp"
                android:textStyle="bold" />
        </FrameLayout>

        <!-- Caller name -->
        <TextView
            android:id="@+id/caller_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold"
            android:gravity="center" />

        <!-- Call type -->
        <TextView
            android:id="@+id/call_type"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="#99FFFFFF"
            android:textSize="16sp"
            android:gravity="center" />

        <!-- Countdown -->
        <TextView
            android:id="@+id/countdown_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="#66FFFFFF"
            android:textSize="14sp"
            android:gravity="center" />

        <!-- Bottom spacer -->
        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="5" />

        <!-- Buttons -->
        <LinearLayout
            android:id="@+id/buttons_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="32dp">

            <!-- Decline -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginEnd="48dp">

                <ImageButton
                    android:id="@+id/btn_decline"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:background="@drawable/btn_decline_call"
                    android:src="@drawable/ic_call_decline"
                    android:scaleType="centerInside"
                    android:padding="18dp"
                    android:contentDescription="Decline"
                    android:elevation="6dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/call_decline"
                    android:textColor="#99FFFFFF"
                    android:textSize="13sp"
                    android:layout_marginTop="8dp" />
            </LinearLayout>

            <!-- Accept -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginStart="48dp">

                <ImageButton
                    android:id="@+id/btn_accept"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:background="@drawable/btn_accept_call"
                    android:src="@drawable/ic_call_accept"
                    android:scaleType="centerInside"
                    android:padding="18dp"
                    android:contentDescription="Accept"
                    android:elevation="6dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/call_accept"
                    android:textColor="#99FFFFFF"
                    android:textSize="13sp"
                    android:layout_marginTop="8dp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
